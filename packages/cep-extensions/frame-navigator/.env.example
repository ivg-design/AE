# ZXP Signing Configuration
# Copy this file to .env.local and set your actual values
# DO NOT commit .env.local to version control

# Password for signing ZXP packages
ZXP_PASSWORD=your_secure_password_here

# Optional: Certificate details (if different from defaults)
# ZXP_COUNTRY=US
# ZXP_PROVINCE=CA
# ZXP_ORG=YourCompany